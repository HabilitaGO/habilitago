# =============================================================================
# HabilitaGO — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit your .env file to version control.
# =============================================================================

# --- App ---
NODE_ENV=development
PORT=5000

# --- Database ---
DATABASE_URL=postgresql://user:password@localhost:5432/habilitago

# --- Session ---
SESSION_SECRET=your-session-secret-minimum-32-characters

# --- Public URLs ---
PUBLIC_WEB_BASE_URL=http://localhost:5000
PUBLIC_API_BASE_URL=http://localhost:5000
WEB_CANONICAL_BASE_URL=http://localhost:5000
CORS_ALLOWED_ORIGINS=http://localhost:5000

# --- Payments: Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Payments: MercadoPago (PIX) ---
MERCADO_PAGO_ACCESS_TOKEN=TEST-...

# --- Email: Resend ---
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@habilitago.com

# --- File Storage (S3-compatible) ---
UPLOADS_STORAGE_DRIVER=local          # 'local' for dev, 's3' for production
# UPLOADS_S3_BUCKET=habilitago-uploads
# UPLOADS_S3_REGION=us-east-1
# UPLOADS_S3_ACCESS_KEY_ID=...
# UPLOADS_S3_SECRET_ACCESS_KEY=...
# UPLOADS_S3_ENDPOINT=https://...     # For non-AWS S3-compatible services

# --- Crypto ---
CRYPTO_MODE=local                     # 'local' or 'kms'
# KMS_KEY_ID=...                      # Required only for CRYPTO_MODE=kms
# CRYPTO_WRAPPED_DEKS_JSON=...
# CRYPTO_ACTIVE_KID=...

# --- Admin Bootstrap ---
SUPER_ADMIN_EMAIL=admin@habilitago.com
SUPER_ADMIN_PASSWORD=change-me-in-production

# --- Client (Vite) ---
VITE_PUBLIC_WEB_BASE_URL=http://localhost:5000
